# Server
PORT=3000
NODE_ENV=development
JWT_SECRET=change-this-to-a-long-random-string-in-production
SITE_URL=http://localhost:3000

# Default admin (created on first seed)
ADMIN_EMAIL=admin@archafricabureau.com
ADMIN_PASSWORD=ChangeMeAdmin123!

# Stripe — https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Live chat — https://www.tawk.to/ (Dashboard → Administration → Property ID)
TAWK_PROPERTY_ID=
TAWK_WIDGET_ID=default

# Email (SMTP or reusable service)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@example.com
EMAIL_PASSWORD=your-email-password
EMAIL_FROM="Arch Africa Bureau <no-reply@archafricabureau.com>"
# Optional manual SMTP config if not using a named service
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
